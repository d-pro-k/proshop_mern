      "parameters": {
        "jsCode": "// B.3 replay cooldown — persist last_disabled_at on confirmed deactivate.\n// Runs after the AI Agent on the merged path; guards on action_taken so reenable\n// and no_op runs do not overwrite the timestamp.\nconst output = $json.output || {};\nconst featureId = $('Merge Data').item.json.feature_id;\n\nif (output.action_taken === 'deactivated') {\n  const staticData = $getWorkflowStaticData('global');\n  if (!staticData.feature_state) staticData.feature_state = {};\n  if (!staticData.feature_state[featureId]) staticData.feature_state[featureId] = {};\n  staticData.feature_state[featureId].last_disabled_at = Date.now();\n}\n\nreturn [{ json: $json }];"
      },

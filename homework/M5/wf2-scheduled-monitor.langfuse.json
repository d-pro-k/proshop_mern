    {
      "parameters": {
        "jsCode": "const fs = require('fs');\nconst path = '/data/logs/logs.json';\nconst data = JSON.parse(fs.readFileSync(path, 'utf-8'));\n\nconst now = Date.now();\nconst window_ms = 60 * 1000;\nconst recent = data.filter(e => (now - new Date(e.timestamp).getTime()) < window_ms);\n\nconst total = recent.length;\nconst errors = recent.filter(e => e.status === 'error').length;\nconst error_rate = total > 0 ? errors / total : 0;\n\nreturn [{ json: { feature_id: 'search_v2', error_rate, total, errors } }];"
      },
      "id": "2ab31f80-bf82-461d-b7e5-ea3e5ac68cd0",
      "name": "Read & Analyze Logs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -688,
        224
      ]
    },
    {
      "parameters": {
        "url": "=http://host.docker.internal:5001/api/feature-flags/{{ $json.feature_id }}",
        "options": {}
      },

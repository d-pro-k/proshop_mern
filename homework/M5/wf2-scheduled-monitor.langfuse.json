      "id": "a7b8c9d0-e1f2-3456-7890-789012345678",
      "name": "Telegram — Decline Ack",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        1320,
        -240
      ],
      "webhookId": "7cd4def0-3456-6789-abcd-ef0123456789",

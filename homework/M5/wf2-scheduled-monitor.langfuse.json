    {
      "parameters": {
        "jsCode": "// B.3 replay cooldown — read last_disabled_at from workflow staticData\n// and inject cooldown flags into the payload so Switch can gate the reenable branch.\nconst featureId = $json.feature_id;\nconst cooldownMs = 3 * 60 * 1000;\nconst now = Date.now();\n\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.feature_state) staticData.feature_state = {};\nconst featureState = staticData.feature_state[featureId] || {};\nconst lastDisabledAt = featureState.last_disabled_at || null;\n\nconst cooldownRemainingMs = lastDisabledAt\n  ? Math.max(0, cooldownMs - (now - lastDisabledAt))\n  : 0;\nconst cooldownActive = cooldownRemainingMs > 0;\n\nreturn [{ json: {\n  ...$json,\n  last_disabled_at: lastDisabledAt,\n  cooldown_remaining_ms: cooldownRemainingMs,\n  cooldown_active: cooldownActive\n}}];"
      },
      "id": "c1d2e3f4-5a6b-7c8d-9e0f-111213141516",

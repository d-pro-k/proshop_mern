        "url": "=http://host.docker.internal:5001/api/feature-flags/{{ $json.feature_id }}",
        "options": {}
      },
      "id": "144b79fa-e854-4978-af48-3485bbb412d6",
      "name": "Get Feature Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -480,
        224
      ]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: {\n  feature_id: $('Read & Analyze Logs').item.json.feature_id,\n  error_rate: $('Read & Analyze Logs').item.json.error_rate,\n  total: $('Read & Analyze Logs').item.json.total,\n  errors: $('Read & Analyze Logs').item.json.errors,\n  current_status: $('Get Feature Status').item.json.status,\n  current_traffic: $('Get Feature Status').item.json.traffic_percentage\n}}];"
      },

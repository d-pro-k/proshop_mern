{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "description": "ProShop M4 design tokens — hybrid D (CSS Modules + native HTML + direct CSS variables). Mirror of frontend/src/styles/design-tokens.css. Edit both files together when changing tokens; see assignments/M4/plan/ext-c-selection-mode.md for the sync rule.",
  "_meta": {
    "stack": "hybrid D — react-bootstrap shell + native HTML + CSS Modules + --ff-* tokens. Pivot from shadcn/Tailwind on 2026-05-16 (see assignments/M4/plan/part2-hybrid-d-decision.md).",
    "prefix": "--ff-",
    "format-policy": "Direct hex / rgba / value strings — NO hsl(var()) composition (CRA 3.4.3 + webpack 4 has resolve issues with composition, see assignments/M4/plan/part2-hybrid-d-decision.md §Технические решения).",
    "consumer-files": [
      "frontend/src/styles/design-tokens.css (runtime mirror)",
      "frontend/src/screens/admin/*.module.css (Часть 2 + Часть 3)",
      "frontend/src/screens/storefront/*.module.css (Часть 4)",
      "frontend/src/components/{Header,Footer,SearchBox}.module.css (Часть 4 Q8 chrome)"
    ]
  },
  "color": {
    "foundations": {
      "bg": { "value": "#FFFFFF", "format": "hex", "css-var": "--ff-bg" },
      "fg": { "value": "#0A2540", "format": "hex", "css-var": "--ff-fg", "_note": "Stripe Slate" },
      "muted": { "value": "#64748B", "format": "hex", "css-var": "--ff-muted" },
      "border": { "value": "#E2E8F0", "format": "hex", "css-var": "--ff-border" }
    },
    "sidebar": {
      "bg": { "value": "#0A2540", "format": "hex", "css-var": "--ff-sidebar-bg", "_note": "Same Slate as --ff-fg, used by admin Sidebar (Часть 2/3) + Header/Footer (Часть 4 Q8 chrome)" },
      "text": { "value": "rgba(255, 255, 255, 0.72)", "format": "rgba", "css-var": "--ff-sidebar-text" },
      "text-strong": { "value": "#FFFFFF", "format": "hex", "css-var": "--ff-sidebar-text-strong" },
      "hover-bg": { "value": "rgba(255, 255, 255, 0.06)", "format": "rgba", "css-var": "--ff-sidebar-hover-bg" },
      "active-bg": { "value": "rgba(255, 255, 255, 0.10)", "format": "rgba", "css-var": "--ff-sidebar-active-bg" },
      "section-label": { "value": "rgba(255, 255, 255, 0.45)", "format": "rgba", "css-var": "--ff-sidebar-section-label" },
      "divider": { "value": "rgba(255, 255, 255, 0.10)", "format": "rgba", "css-var": "--ff-sidebar-divider" }
    },
    "accent": {
      "primary": { "value": "#0EA5E9", "format": "hex", "css-var": "--ff-accent", "_note": "Sky-500, used for primary CTAs and interactive states" },
      "ring": { "value": "rgba(14, 165, 233, 0.20)", "format": "rgba", "css-var": "--ff-accent-ring", "_note": "focus-visible glow" },
      "hover": { "value": "#0284C7", "format": "hex", "css-var": "--ff-accent-hover", "_note": "Sky-600, used by Part 4 SearchBox button hover + cleanup target for inline #0284C7 in ProductList" }
    },
    "status": {
      "enabled": {
        "bg": { "value": "#DCFCE7", "format": "hex", "css-var": "--ff-status-enabled-bg" },
        "text": { "value": "#047857", "format": "hex", "css-var": "--ff-status-enabled-text" }
      },
      "testing": {
        "bg": { "value": "#E0F2FE", "format": "hex", "css-var": "--ff-status-testing-bg" },
        "text": { "value": "#075985", "format": "hex", "css-var": "--ff-status-testing-text" }
      },
      "disabled": {
        "bg": { "value": "#F1F5F9", "format": "hex", "css-var": "--ff-status-disabled-bg" },
        "text": { "value": "#475569", "format": "hex", "css-var": "--ff-status-disabled-text" }
      }
    },
    "toggle": {
      "off-bg": { "value": "#CBD5E1", "format": "hex", "css-var": "--ff-toggle-off-bg" },
      "knob-shadow": { "value": "0 1px 2px rgba(0, 0, 0, 0.2)", "css-var": "--ff-toggle-knob-shadow", "_note": "Toggle knob elevation (FeatureFlagsScreen)" }
    },
    "row": {
      "head-bg": { "value": "#F8FAFC", "format": "hex", "css-var": "--ff-row-head-bg", "_note": "Table thead background; also dropdown-item hover bg" },
      "border": { "value": "#F1F5F9", "format": "hex", "css-var": "--ff-row-border" },
      "hover-bg": { "value": "rgba(14, 165, 233, 0.05)", "format": "rgba", "css-var": "--ff-row-hover-bg", "_note": "Admin tables row:hover — subtle accent-blue tint" },
      "disabled-bg": { "value": "#FAFBFC", "format": "hex", "css-var": "--ff-row-disabled-bg", "_note": "FeatureFlagsScreen disabled row — between bg (#FFF) and slate-50, distinct from row-head" }
    },
    "dropdown": {
      "item-hover-bg": { "value": "#F1F5F9", "format": "hex", "css-var": "--ff-dropdown-item-hover-bg", "_note": "Semantic alias for Header dropdown-item :hover / :focus-visible (value coincidentally matches --ff-row-border)" }
    },
    "skeleton": {
      "bg": { "value": "#F1F5F9", "format": "hex", "css-var": "--ff-skeleton-bg" }
    },
    "error": {
      "bg": { "value": "#FEF2F2", "format": "hex", "css-var": "--ff-error-bg" },
      "border": { "value": "#FECACA", "format": "hex", "css-var": "--ff-error-border" },
      "fg": { "value": "#991B1B", "format": "hex", "css-var": "--ff-error-fg" }
    },
    "role": {
      "admin": {
        "bg": { "value": "#E0F2FE", "format": "hex", "css-var": "--ff-role-admin-bg" },
        "text": { "value": "#075985", "format": "hex", "css-var": "--ff-role-admin-text" }
      },
      "customer": {
        "bg": { "value": "#F1F5F9", "format": "hex", "css-var": "--ff-role-customer-bg" },
        "text": { "value": "#475569", "format": "hex", "css-var": "--ff-role-customer-text" }
      }
    },
    "modal": {
      "overlay-bg": { "value": "rgba(0, 0, 0, 0.4)", "format": "rgba", "css-var": "--ff-modal-overlay-bg" },
      "shadow": { "value": "0 10px 25px rgba(0, 0, 0, 0.15)", "css-var": "--ff-modal-shadow", "_note": "Shared modal panel elevation (ProductList, UserList, and other admin modals)" }
    },
    "search": {
      "input-focus-bg": { "value": "rgba(255, 255, 255, 0.16)", "format": "rgba", "css-var": "--ff-search-input-focus-bg", "_note": "Q8 chrome SearchBox :focus bg over dark Header — slightly brighter than --ff-sidebar-active-bg (0.10)" }
    },
    "danger": {
      "bg": { "value": "#DC2626", "format": "hex", "css-var": "--ff-danger-bg" },
      "bg-hover": { "value": "#B91C1C", "format": "hex", "css-var": "--ff-danger-bg-hover" },
      "fg": { "value": "#991B1B", "format": "hex", "css-var": "--ff-danger-fg" },
      "soft-bg": { "value": "#FEF2F2", "format": "hex", "css-var": "--ff-danger-soft-bg" },
      "soft-border": { "value": "#FECACA", "format": "hex", "css-var": "--ff-danger-soft-border" }
    },
    "star": {
      "active": { "value": "#F59E0B", "format": "hex", "css-var": "--ff-star-active", "_note": "Amber-500 for rating stars (warmer than accent blue)" },
      "inactive": { "value": "#E2E8F0", "format": "hex", "css-var": "--ff-star-inactive" }
    }
  },
  "radius": {
    "_note": "Named numeric radius scale. 50% (full circle) and 2px (one-off) stay inline. The storefront-specific 12px lives under storefront.product-card-radius — do NOT use it for non-storefront 12px.",
    "sm": { "value": "4px", "css-var": "--ff-radius-sm" },
    "md": { "value": "6px", "css-var": "--ff-radius-md" },
    "lg": { "value": "8px", "css-var": "--ff-radius-lg" },
    "pill": { "value": "999px", "css-var": "--ff-radius-pill" }
  },
  "typography": {
    "font-sans": {
      "value": "'Geist', system-ui, -apple-system, 'Segoe UI', sans-serif",
      "css-var": "--ff-font-sans",
      "_note": "Geist loaded via Google Fonts <link> in frontend/public/index.html (Часть 2). Fallback to system-ui per DESIGN.md anti-AI-slop rule (NOT Inter)."
    }
  },
  "storefront": {
    "_note": "storefront-comfortable density subset (Часть 4 — Home/Cart/Product details). Distinct from admin-dense Части 2/3.",
    "max-width": { "value": "1200px", "css-var": "--ff-storefront-max-width" },
    "section-gap": { "value": "48px", "css-var": "--ff-storefront-section-gap" },
    "block-gap": { "value": "64px", "css-var": "--ff-storefront-block-gap", "_note": "added but unused in 4.x — cleanup in M5" },
    "card-padding": { "value": "24px", "css-var": "--ff-card-padding-storefront" },
    "product-card-radius": { "value": "12px", "css-var": "--ff-product-card-radius" },
    "product-image-aspect": { "value": "1 / 1", "css-var": "--ff-product-image-aspect" },
    "hero-h1-size": { "value": "48px", "css-var": "--ff-hero-h1-size" },
    "hero-h1-size-mobile": { "value": "32px", "css-var": "--ff-hero-h1-size-mobile" },
    "hero-padding-y": { "value": "32px", "css-var": "--ff-hero-padding-y", "_note": "added but unused in 4.x — cleanup in M5" },
    "carousel-overlay-bg": { "value": "rgba(10, 37, 64, 0.55)", "format": "rgba", "css-var": "--ff-carousel-overlay-bg", "_note": "added but unused in final 4.x Carousel — cleanup in M5" },
    "carousel-arrow-bg": { "value": "rgba(255, 255, 255, 0.10)", "format": "rgba", "css-var": "--ff-carousel-arrow-bg" },
    "carousel-arrow-bg-hover": { "value": "rgba(255, 255, 255, 0.20)", "format": "rgba", "css-var": "--ff-carousel-arrow-bg-hover" },
    "carousel-dot-bg": { "value": "rgba(255, 255, 255, 0.30)", "format": "rgba", "css-var": "--ff-carousel-dot-bg" },
    "carousel-dot-bg-active": { "value": "#FFFFFF", "format": "hex", "css-var": "--ff-carousel-dot-bg-active" },
    "card-shadow": { "value": "0 1px 3px rgba(10, 37, 64, 0.06)", "css-var": "--ff-card-shadow" },
    "card-shadow-hover": { "value": "0 4px 12px rgba(10, 37, 64, 0.10)", "css-var": "--ff-card-shadow-hover" }
  }
}
